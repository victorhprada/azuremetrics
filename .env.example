# Azure DevOps — copie para .env e preencha com valores reais
AZURE_DEVOPS_ORGANIZACAO=wiipo
AZURE_DEVOPS_PROJETO=Wiipo
AZURE_DEVOPS_TEAM=Plataforma
AZURE_DEVOPS_PAT=troque-pelo-seu-pat
AZURE_DEVOPS_NUM_SPRINTS=1

# Gemini (opcional)
GEMINI_API_KEY=

# Comportamento local
OPEN_BROWSER=true

# Status Page (opcional) — título exibido na página pública
STATUS_PAGE_TITLE=Status da Sprint — Plataforma
